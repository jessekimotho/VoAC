{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"import:migration": "node --env-file=.env.local scripts/import-migration.mjs",
		"import:comments": "node --env-file=.env.local scripts/import-comments.mjs",
		"audit:links": "node --env-file=.env.local scripts/audit-links.mjs",
		"fix:links": "node --env-file=.env.local scripts/audit-links.mjs --fix"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.104.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@tiptap/core": "^3.22.4",
		"@tiptap/extension-image": "^3.22.4",
		"@tiptap/extension-link": "^3.22.4",
		"@tiptap/pm": "^3.22.4",
		"@tiptap/starter-kit": "^3.22.4"
	}
}
